'use client'
import { useState } from 'react';
import { AppShell, Burger, Group, Drawer, Box, Center, Text } from '@mantine/core';
import SidebarContent from "../SidebarContent/SibebarContent";
import styles from "./AppStyles.module.css";

export default function AppShellClient({ children }: { children: React.ReactNode }) {
    const [isOpen, setIsOpen] = useState(false);
    let toggle = () => setIsOpen(prev => !prev);

    return (
        <AppShell
        layout="alt"
            padding="md"
            header={{ height: 60 }}
            navbar={{
                width: 280,
                breakpoint: 'sm',
                collapsed: { mobile: true }
            }}
        >
            <AppShell.Header>
                <Group h="100%" px="md">
                    <Burger
                        opened={isOpen}
                        onClick={toggle}
                        hiddenFrom="sm"
                        size="sm"
                    />
                    <Box hiddenFrom="sm" className={styles.logo}>OFF-WORK</Box>
                </Group>
            </AppShell.Header>

            <AppShell.Navbar >
                <SidebarContent />
            </AppShell.Navbar>

            <Drawer.Root
                opened={isOpen}
                onClose={toggle}
                size={280}
                transitionProps={{ duration: 200, transition: 'slide-right' }}
                styles={{
                    content: { backgroundColor: '#0d0d0d' },
                    header: { backgroundColor: '#0d0d0d' },
                }}
            >
                <Drawer.Overlay />
                <Drawer.Content>
                    <Drawer.Header>
                        <Drawer.Title>
                            <Group>
                                <Group>
                                    <span style={{ color: 'green' }}>●</span>
                                    <Text style={{color: 'white'}}>OFF-DESK</Text>
                                </Group>
                            </Group>
                        </Drawer.Title>
                        <Drawer.CloseButton />
                    </Drawer.Header>
                    <Drawer.Body>Drawer content</Drawer.Body>
                </Drawer.Content>
            </Drawer.Root>

            {children}
        </AppShell >
    )
}
